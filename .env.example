# ─────────────────────────────────────────────────────────────
# Micrositio de recursos Fromus — variables de entorno
# Copia este archivo a `.env.local` y rellena con tus valores reales.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (sin slash final). Se usa para construir los
# enlaces a las guías y el enlace de baja en los correos.
# Ej.: https://recursos.fromus.tech
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# Settings → API en el dashboard de Supabase.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# service_role key (SECRETA — solo lado servidor, nunca en el browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Resend ────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Remitente verificado en Resend (dominio fromus.tech con SPF/DKIM)
RESEND_FROM="Fromus <recursos@fromus.tech>"

# ── Seguridad ─────────────────────────────────────────────────
# Secreto para firmar los enlaces de baja (HMAC). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET=replace-with-a-long-random-secret
